# Fixture definition for the C oracle harness (tools/oracle/harness).
# See tools/oracle/gen-fixtures.sh for the format this file is parsed with:
# plain "key=value" lines, one per line, "#" starts a comment.
#
# dat        - .dat filename, resolved relative to tworld/data/
# level      - level index within the .dat file (0-based)
# ruleset    - "ms" or "lynx"
# rndseed    - seed passed to restartprng()
# rndslidedir- initial random-slide direction (0/1/2/4/8)
# stepping   - initial timer stepping offset (0-7)
# maxTicks   - number of ticks to simulate
# moves      - space-separated "when:dir" pairs (dir: 0=NIL 1=N 2=W 4=S 8=E)
#
# intro.dat level 5, "TELEPORTS AND THIEVES" under the MS ruleset -- Chip
# walks east repeatedly, picking up an item (chipsNeeded decrements) and a
# boot (boots[3] set), exercising item pickup and chipsneeded bookkeeping
# under MS's tile/sound-effect logic.

dat=intro.dat
level=5
ruleset=ms
rndseed=1
rndslidedir=0
stepping=0
maxTicks=30
moves=0:8 4:8 8:8 12:8 16:8 20:8
